<%
  form           = stats[:form]
  days           = stats[:days_until_etape]
  history_json   = stats[:history].to_json
  weeks          = stats[:weekly_summary]
  recent         = stats[:recent_activities]
  max_km         = weeks.map { |w| w[:km] }.max.to_f
%>

<div class="max-w-5xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
      <span class="text-3xl">🚴</span>
      <div>
        <h1 class="text-xl font-bold text-slate-800">Dashboard Vélo</h1>
        <p class="text-slate-500 text-sm">Bonjour <%= athlete['firstname'] %> !</p>
      </div>
    </div>
    <div class="flex gap-2">
      <form method="post" action="/refresh">
        <button class="text-sm bg-slate-100 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-lg transition-colors">
          ↻ Actualiser
        </button>
      </form>
      <button id="btn-report"
              class="text-sm bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-lg transition-colors">
        📧 Rapport email
      </button>
      <a href="/logout" class="text-sm bg-slate-100 hover:bg-slate-200 text-slate-600 px-4 py-2 rounded-lg transition-colors">
        Déconnexion
      </a>
    </div>
  </div>

  <!-- Countdown -->
  <div class="bg-gradient-to-r from-orange-500 to-orange-400 rounded-2xl p-6 text-white mb-6 shadow-sm">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-orange-100 text-sm font-medium uppercase tracking-wide">Étape du Tour 2026</p>
        <p class="text-5xl font-black mt-1">J-<%= days %></p>
        <p class="text-orange-100 mt-1">19 juillet 2026</p>
      </div>
      <div class="text-right">
        <div class="bg-white/20 rounded-xl p-4">
          <p class="text-sm text-orange-100">Statut forme</p>
          <p class="text-xl font-bold mt-1"><%= form[:label] %></p>
          <p class="text-xs text-orange-100 mt-1 max-w-[140px]"><%= form[:advice] %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- CTL / ATL / TSB -->
  <div class="grid grid-cols-3 gap-4 mb-6">
    <% [
      { label: 'CTL', value: stats[:ctl], unit: 'Forme (42j)', color: 'blue',   tip: 'Plus c\'est haut, meilleure est ta condition physique' },
      { label: 'ATL', value: stats[:atl], unit: 'Fatigue (7j)', color: 'red',    tip: 'Fatigue récente — baisse après récupération' },
      { label: 'TSB', value: stats[:tsb], unit: 'Fraîcheur',    color: 'green',  tip: 'CTL − ATL. Objectif : +10 à +20 le jour J' }
    ].each do |m| %>
      <div class="stat-card bg-white rounded-xl p-5 shadow-sm border border-slate-100" title="<%= m[:tip] %>">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= m[:unit] %></p>
        <p class="text-4xl font-black mt-1
          <%= m[:label] == 'TSB' ? (stats[:tsb] >= 5 ? 'text-green-600' : stats[:tsb] >= -10 ? 'text-amber-500' : 'text-red-500') : "text-#{m[:color]}-600" %>">
          <%= m[:value] %>
        </p>
        <p class="text-sm font-bold text-slate-600 mt-1"><%= m[:label] %></p>
      </div>
    <% end %>
  </div>

  <!-- Chart -->
  <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 mb-6">
    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4">Évolution CTL / ATL / TSB — 60 derniers jours</h2>
    <canvas id="chart" height="90"></canvas>
  </div>

  <!-- Weekly summary -->
  <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100 mb-6">
    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4">Résumé par semaine</h2>
    <div class="grid grid-cols-4 gap-3">
      <% weeks.each do |w| %>
        <div class="bg-slate-50 rounded-lg p-3">
          <p class="text-xs font-semibold text-slate-500 mb-2"><%= w[:label] %></p>
          <div class="h-1 bg-slate-200 rounded mb-2">
            <div class="h-1 bg-orange-400 rounded" style="width: <%= max_km > 0 ? (w[:km] / max_km * 100).round : 0 %>%"></div>
          </div>
          <p class="text-lg font-bold text-slate-700"><%= w[:km] %> km</p>
          <p class="text-xs text-slate-400"><%= w[:elevation] %> m D+</p>
          <p class="text-xs text-slate-400"><%= w[:hours] %>h · <%= w[:count] %> sorties</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent activities -->
  <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-100">
    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4">Dernières sorties</h2>
    <% if recent.empty? %>
      <p class="text-slate-400 text-sm">Aucune sortie trouvée.</p>
    <% else %>
      <div class="divide-y divide-slate-50">
        <% recent.each do |a| %>
          <div class="flex items-center justify-between py-3 hover:bg-slate-50 -mx-2 px-2 rounded-lg transition-colors">
            <div class="flex items-center gap-3">
              <span class="text-lg"><%= a['type'] == 'VirtualRide' ? '🖥️' : '🚴' %></span>
              <div>
                <p class="font-medium text-slate-700 text-sm"><%= a['name'] %></p>
                <p class="text-xs text-slate-400">
                  <%= Date.parse(a['start_date_local']).strftime('%d %b %Y') %>
                </p>
              </div>
            </div>
            <div class="flex gap-4 text-right">
              <div>
                <p class="text-sm font-semibold text-slate-700"><%= (a['distance'].to_f / 1000).round(1) %> km</p>
                <p class="text-xs text-slate-400">distance</p>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-700"><%= a['total_elevation_gain'].to_i %> m</p>
                <p class="text-xs text-slate-400">dénivelé</p>
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-700">
                  <% s = a['moving_time'].to_i; h = s/3600; m = (s%3600)/60 %>
                  <%= "#{h}h#{m.to_s.rjust(2,'0')}" %>
                </p>
                <p class="text-xs text-slate-400">durée</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <p class="text-center text-xs text-slate-300 mt-6">Données Strava · Mis à jour toutes les 6h</p>
</div>

<!-- Toast notification -->
<div id="toast" class="fixed bottom-6 right-6 bg-slate-800 text-white px-5 py-3 rounded-xl shadow-lg text-sm transition-all opacity-0 translate-y-2 pointer-events-none">
  <span id="toast-msg"></span>
</div>

<script>
  // Chart
  const raw = <%= history_json %>;
  const last60 = raw.slice(-60);
  const labels = last60.map(d => {
    const [y, m, day] = d.date.split('-');
    return `${day}/${m}`;
  });

  new Chart(document.getElementById('chart'), {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'CTL', data: last60.map(d => d.ctl), borderColor: '#3b82f6', backgroundColor: 'transparent', borderWidth: 2, pointRadius: 0, tension: 0.3 },
        { label: 'ATL', data: last60.map(d => d.atl), borderColor: '#ef4444', backgroundColor: 'transparent', borderWidth: 2, pointRadius: 0, tension: 0.3 },
        { label: 'TSB', data: last60.map(d => d.tsb), borderColor: '#16a34a', backgroundColor: 'transparent', borderWidth: 1.5, borderDash: [4,3], pointRadius: 0, tension: 0.3 }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { labels: { boxWidth: 12, font: { size: 11 } } } },
      scales: {
        x: { ticks: { maxTicksLimit: 10, font: { size: 10 } }, grid: { display: false } },
        y: { ticks: { font: { size: 10 } } }
      }
    }
  });

  // Email report button
  function showToast(msg, ok) {
    const t = document.getElementById('toast');
    const m = document.getElementById('toast-msg');
    m.textContent = msg;
    t.classList.toggle('bg-green-700', ok);
    t.classList.toggle('bg-red-700', !ok);
    t.classList.toggle('bg-slate-800', false);
    t.classList.remove('opacity-0', 'translate-y-2');
    setTimeout(() => t.classList.add('opacity-0', 'translate-y-2'), 3500);
  }

  document.getElementById('btn-report').addEventListener('click', async () => {
    const btn = document.getElementById('btn-report');
    btn.disabled = true;
    btn.textContent = 'Envoi…';
    try {
      const res  = await fetch('/report', { method: 'POST' });
      const data = await res.json();
      showToast(data.message, data.success);
    } catch(e) {
      showToast('Erreur réseau', false);
    } finally {
      btn.disabled = false;
      btn.textContent = '📧 Rapport email';
    }
  });
</script>
