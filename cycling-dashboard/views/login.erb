<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-orange-50 to-slate-100">
  <div class="bg-white rounded-2xl shadow-lg p-10 text-center max-w-md w-full mx-4">

    <div class="text-5xl mb-4">🚴</div>
    <h1 class="text-2xl font-bold text-slate-800 mb-1">Dashboard Vélo</h1>
    <p class="text-slate-500 mb-2">Préparation Étape du Tour 2026</p>

    <div class="bg-orange-50 border border-orange-200 rounded-xl p-4 mb-8">
      <p class="text-orange-800 font-semibold text-lg">19 juillet 2026</p>
      <p class="text-orange-600 text-sm">J-<%= (Date.new(2026, 7, 19) - Date.today).to_i %> jours</p>
