      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-8.466 16.713h4.172"/>
      </svg>
      Connecter Strava
    </a>

    <p class="text-xs text-slate-400 mt-4">Lecture seule — aucune donnée modifiée sur Strava</p>
  </div>
</div>
