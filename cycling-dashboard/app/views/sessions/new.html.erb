<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-orange-50 to-slate-100 -mt-0">
  <div class="bg-white rounded-2xl shadow-lg p-10 text-center max-w-md w-full mx-4">

    <div class="text-5xl mb-4">🚴</div>
    <h1 class="text-2xl font-bold text-slate-800 mb-1">Dashboard Vélo</h1>
    <p class="text-slate-500 mb-6 text-sm">Suivi CTL / ATL / TSB · Préparation Étape du Tour</p>

    <div class="bg-orange-50 border border-orange-200 rounded-xl p-4 mb-8">
      <p class="text-orange-700 text-xs font-semibold uppercase tracking-wide mb-1">Objectif</p>
      <p class="text-orange-800 font-bold text-xl">Étape du Tour 2026</p>
      <p class="text-orange-600 font-semibold">19 juillet · J-<%= (Date.new(2026, 7, 19) - Date.today).to_i %></p>
    </div>

    <%= link_to @auth_url,
          class: "flex items-center justify-center gap-3 bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-3 rounded-xl transition-colors w-full" do %>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-8.466 16.713h4.172"/>
      </svg>
      Connecter avec Strava
    <% end %>

    <p class="text-xs text-slate-400 mt-4">Accès lecture seule · Aucune modification sur Strava</p>
  </div>
</div>
