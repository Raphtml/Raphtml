<!-- Stats globales -->
<div class="grid grid-cols-3 gap-4 mb-6">
  <% [
    { label: "Total km",    value: number_with_delimiter(@total_km.to_i),  unit: "km" },
    { label: "Total D+",   value: number_with_delimiter(@total_elev.to_i), unit: "m" },
    { label: "Total heures", value: @total_h, unit: "h" }
  ].each do |s| %>
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100 text-center">
      <p class="text-3xl font-black text-orange-500"><%= s[:value] %> <span class="text-lg"><%= s[:unit] %></span></p>
      <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mt-1"><%= s[:label] %></p>
    </div>
  <% end %>
</div>

<!-- Table -->
<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
  <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
    <h2 class="font-semibold text-slate-700">Toutes les sorties (<%= current_athlete.rides.count %>)</h2>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-xs text-slate-400 uppercase tracking-wide">
        <tr>
          <th class="px-6 py-3 text-left">Date</th>
          <th class="px-6 py-3 text-left">Sortie</th>
          <th class="px-6 py-3 text-right">Distance</th>
          <th class="px-6 py-3 text-right">D+</th>
          <th class="px-6 py-3 text-right">Durée</th>
          <th class="px-6 py-3 text-right">TSS</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <% @activities.each do |a| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-3 text-slate-500 whitespace-nowrap">
              <%= a.start_date_local.strftime("%d %b %Y") %>
            </td>
            <td class="px-6 py-3">
              <div class="flex items-center gap-2">
                <span><%= a.trainer? ? "🖥️" : "🚴" %></span>
                <span class="font-medium text-slate-700 truncate max-w-xs"><%= a.name %></span>
              </div>
            </td>
            <td class="px-6 py-3 text-right font-semibold text-slate-700"><%= a.distance_km %> km</td>
            <td class="px-6 py-3 text-right text-slate-600"><%= a.total_elevation_gain.to_i %> m</td>
            <td class="px-6 py-3 text-right text-slate-600"><%= a.duration_formatted %></td>
            <td class="px-6 py-3 text-right">
              <span class="font-semibold <%= a.tss.to_f > 100 ? 'text-red-500' : a.tss.to_f > 60 ? 'text-amber-500' : 'text-green-600' %>">
                <%= a.tss&.round(0) || "—" %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
