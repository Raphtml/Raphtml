<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Dashboard Vélo — Étape du Tour 2026" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 min-h-screen text-slate-800">
    <% if logged_in? %>
      <nav class="bg-white border-b border-slate-200 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2 font-bold text-slate-800">
          <span class="text-xl">🚴</span>
          <span>Dashboard Vélo</span>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <%= link_to "Dashboard", root_path, class: "text-slate-600 hover:text-orange-500 font-medium" %>
          <%= link_to "Activités", activities_path, class: "text-slate-600 hover:text-orange-500 font-medium" %>
          <div class="flex items-center gap-2 ml-4 pl-4 border-l border-slate-200">
            <% if current_athlete.profile_medium.present? %>
              <img src="<%= current_athlete.profile_medium %>" class="w-7 h-7 rounded-full" alt="">
            <% end %>
            <span class="text-slate-500"><%= current_athlete.firstname %></span>
            <%= button_to "Déconnexion", logout_path, method: :delete,
                  class: "text-slate-400 hover:text-red-500 text-xs" %>
          </div>
        </div>
      </nav>
    <% end %>

    <% flash.each do |type, msg| %>
      <div class="mx-6 mt-4 px-4 py-3 rounded-lg text-sm font-medium
                  <%= type == 'notice' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' %>">
        <%= msg %>
      </div>
    <% end %>

    <main class="<%= logged_in? ? 'max-w-5xl mx-auto px-4 py-8' : '' %>">
      <%= yield %>
    </main>
  </body>
</html>
