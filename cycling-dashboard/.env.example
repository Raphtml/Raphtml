# ── Strava API ────────────────────────────────────────────────────────────────
# Créer l'app sur : https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://localhost:4567/auth/callback

# ── Rapport email (Gmail) ─────────────────────────────────────────────────────
# Créer un App Password Gmail : https://myaccount.google.com/apppasswords
GMAIL_USER=ton.email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
REPORT_EMAIL=ton.email@gmail.com

# ── Entraînement ──────────────────────────────────────────────────────────────
# FTP en watts (optionnel — améliore la précision du TSS si tu as un capteur de puissance)
FTP=250

# ── App ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_with_a_random_string
