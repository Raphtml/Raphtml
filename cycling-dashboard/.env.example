# ── Strava API ────────────────────────────────────────────────────────────────
# Créer l'app sur : https://www.strava.com/settings/api
# "Authorization Callback Domain" : localhost
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# ── Base de données ───────────────────────────────────────────────────────────
# Laisser vide si PostgreSQL tourne en local avec l'user système
DB_HOST=localhost
DB_USER=
DB_PASSWORD=

# ── Rapport email (Gmail) ─────────────────────────────────────────────────────
# Créer un App Password Gmail : https://myaccount.google.com/apppasswords
GMAIL_USER=ton.email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
REPORT_EMAIL=ton.email@gmail.com

# ── Entraînement ──────────────────────────────────────────────────────────────
# FTP en watts (optionnel — améliore la précision du TSS si capteur de puissance)
FTP=250

# ── Rails ─────────────────────────────────────────────────────────────────────
SECRET_KEY_BASE=run_bin/rails_secret_to_generate
